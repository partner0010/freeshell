// Prisma schema for Freeshell monitoring / projects / domains / checks
// DB connection is configured via DATABASE_URL env var (e.g., Supabase Postgres).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  image     String?
  password  String?  // 해시된 비밀번호 (이메일 가입 시)
  phone     String?  @unique // 휴대폰 번호
  phoneVerified Boolean @default(false) // 본인 인증 완료 여부
  verifiedAt DateTime? // 본인 인증 완료 시간
  provider  String?  // 'email' | 'google' | 'naver' | 'kakao'
  providerId String? // 소셜 로그인 제공자 ID
  role      String   @default("user") // 'user' | 'admin' | 'premium'
  subscriptionTier String @default("free") // 'free' | 'pro' | 'enterprise'
  subscriptionExpiresAt DateTime? // 구독 만료일
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects       Project[]       @relation("ProjectOwner")
  projectMembers ProjectMember[]
  accounts       Account[]      // NextAuth 계정
  sessions       Session[]      // NextAuth 세션
  license        SubscriptionLicense? // 구독 라이선스
}

model Project {
  id        String   @id @default(cuid())
  name      String
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner    User           @relation("ProjectOwner", fields: [ownerId], references: [id])
  members  ProjectMember[]
  domains  Domain[]
  settings Json?          // { slackWebhook?: string, thresholds?: {...} }
}

model ProjectMember {
  id        String   @id @default(cuid())
  role      String   // 'owner' | 'admin' | 'viewer' 등
  projectId String
  userId    String
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([projectId, userId])
}

model Domain {
  id              String   @id @default(cuid())
  name            String   @unique
  projectId       String
  lastCheckedAt   DateTime?
  expiresAt       DateTime?
  statusCache     Json?    // latest health summary
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id])
  checks  Check[]
}

model Check {
  id        String   @id @default(cuid())
  domainId  String
  summary   Json     // healthcheck result payload
  createdAt DateTime @default(now())

  domain Domain @relation(fields: [domainId], references: [id])

  @@index([domainId, createdAt])
}

// NextAuth 계정 모델
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

// NextAuth 세션 모델
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// NextAuth 인증 토큰 모델
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// 본인 인증 요청 모델
model IdentityVerification {
  id        String   @id @default(cuid())
  userId    String   @unique
  phone     String
  code      String   // 인증번호
  verified  Boolean  @default(false)
  attempts  Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())
  verifiedAt DateTime?

  @@index([userId])
  @@index([phone])
}

// 구독 라이선스 모델
model SubscriptionLicense {
  id              String   @id @default(cuid())
  licenseKey      String   @unique // 라이선스 키
  userId          String?  @unique // 사용자 ID (null이면 미할당, unique로 one-to-one 관계)
  tier            String   // 'free' | 'pro' | 'enterprise'
  status          String   @default("active") // 'active' | 'expired' | 'revoked' | 'pending'
  issuedAt        DateTime @default(now())
  expiresAt       DateTime? // null이면 무기한
  maxDevices      Int      @default(1) // 최대 사용 가능한 기기 수
  features        Json?    // 추가 기능 목록
  metadata        Json?    // 기타 메타데이터
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User?    @relation(fields: [userId], references: [id])
  usages          LicenseUsage[]

  @@index([licenseKey])
  @@index([userId])
  @@index([status])
}

// 라이선스 사용 기록
model LicenseUsage {
  id              String   @id @default(cuid())
  licenseId       String
  deviceId        String   // 기기 식별자
  deviceInfo      Json?    // 기기 정보
  lastUsedAt      DateTime @default(now())
  createdAt        DateTime @default(now())

  license         SubscriptionLicense @relation(fields: [licenseId], references: [id], onDelete: Cascade)

  @@unique([licenseId, deviceId])
  @@index([licenseId])
}
