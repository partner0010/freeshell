// Prisma schema for Freeshell monitoring / projects / domains / checks
// DB connection is configured via DATABASE_URL env var (e.g., Supabase Postgres).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String    @id @default(cuid())
  email                 String?   @unique
  emailVerified         DateTime?
  name                  String?
  image                 String?
  password              String?   // 비밀번호 해시
  phone                 String?   @unique // 전화번호
  phoneVerified         Boolean   @default(false) // 전화번호 인증 여부
  verifiedAt            DateTime? // 인증 완료 시간
  provider              String?   // OAuth 제공자 (google, naver, kakao)
  providerId            String?   // OAuth 제공자의 사용자 ID
  role                  String    @default("user") // user, admin
  subscriptionTier      String?   // free, basic, premium
  subscriptionExpiresAt DateTime? // 구독 만료일
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  accounts              Account[]
  sessions              Session[]
  licenses              SubscriptionLicense[]
  identityVerifications IdentityVerification[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model IdentityVerification {
  id        String   @id @default(cuid())
  userId    String
  phone     String
  code      String
  verified  Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("identity_verifications")
}

model SubscriptionLicense {
  id          String    @id @default(cuid())
  licenseKey  String    @unique
  tier        String    // free, basic, premium
  status      String    @default("active") // active, expired, revoked
  userId      String?   @unique // 사용자 ID (null이면 미할당, unique로 one-to-one 관계)
  expiresAt   DateTime?
  maxDevices  Int       @default(1)
  issuedAt    DateTime  @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user   User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  usages LicenseUsage[]

  @@map("subscription_licenses")
}

model LicenseUsage {
  id        String   @id @default(cuid())
  licenseId String
  deviceId  String
  deviceInfo String? @db.Text
  lastUsed  DateTime @default(now())
  createdAt DateTime @default(now())

  license SubscriptionLicense @relation(fields: [licenseId], references: [id], onDelete: Cascade)

  @@unique([licenseId, deviceId])
  @@map("license_usages")
}
